# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# When using docker-compose the default points at the bundled `postgres`
# service. For an external database, set a full connection string.
DATABASE_URL=postgresql://ecommerce:ecommerce@postgres:5432/ecommerce

# Credentials for the bundled postgres container (compose only).
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce
POSTGRES_DB=ecommerce

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
